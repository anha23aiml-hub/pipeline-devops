
pipeline {
    agent any
   
    tools {
        maven 'Maven'
        jdk 'JDK'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/anha23aiml-hub/pipeline-devops.git'

            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean package'
            }
        }

        stage('Test') {
            steps {
                bat 'mvn test'
            }
        }
    }
    post {
        always {
                    junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml'

        }
    }
}
